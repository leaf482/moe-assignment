{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "aws-lambda"],
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["bin/**/*.ts", "infra/**/*.ts", "src/**/*.ts"]
}
