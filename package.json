{
  "name": "moe-assignment",
  "version": "1.0.0",
  "description": "Marketplace aggregator prototype for the MOE senior engineer assignment.",
  "main": "index.js",
  "scripts": {
    "build": "tsc --noEmit && npm run build:web",
    "build:web": "node scripts/build-web.mjs",
    "cdk": "cdk",
    "deploy": "npm run build && cdk deploy --all --require-approval never",
    "destroy": "cdk destroy --all --force",
    "smoke": "node scripts/smoke.mjs"
  },
